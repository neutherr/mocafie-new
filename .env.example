# ============================================================
# Mocafie - Environment Variables TEMPLATE (Aman di-commit)
# ============================================================
# Salin file ini menjadi ".env" lalu isi nilai yang sebenarnya.
# cp .env.example .env

# --- RajaOngkir / Komerce ---
RAJAONGKIR_API_KEY=your_rajaongkir_api_key_here

# --- Midtrans ---
MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_SERVER_KEY_HERE
MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_CLIENT_KEY_HERE

# Set ke "true" untuk Mode Produksi (Live), "false" untuk Sandbox
MIDTRANS_IS_PRODUCTION=false
